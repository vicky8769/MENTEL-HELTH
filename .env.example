# MindGuard AI Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mindguard
DATABASE_POOL_SIZE=10

# Redis (for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@mindguard.ai

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=3600000

# Session
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=604800000

# CORS
CORS_ORIGIN=http://localhost:3000

# Analytics (optional)
GOOGLE_ANALYTICS_ID=
SEGMENT_WRITE_KEY=

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_CRISIS_DETECTION=true
ENABLE_GAMIFICATION=true
ENABLE_JOURNAL=true

# Emergency Resources
CRISIS_HOTLINE_US=988
CRISIS_TEXT_US=741741
CRISIS_HOTLINE_IN=112
CRISIS_HOTLINE_UK=111

# Storage (for avatars, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=mindguard-uploads

# Webhooks (optional)
WEBHOOK_SECRET=
WEBHOOK_URL=

# Third-party APIs (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
